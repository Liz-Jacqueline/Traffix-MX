<style>
  /* ===== FOOTER ===== */
  .footer-semaforo {
    position: relative;
    overflow: hidden;
    background: rgba(5, 5, 5, 0.85);
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(75px);
    pointer-events: none;
    animation: drift 9s ease-in-out infinite alternate;
  }
  .orb-red        { width:300px;height:300px;background:radial-gradient(circle,#ff2020 0%,transparent 70%);top:-100px;left:-70px;opacity:.45;animation-delay:0s; }
  .orb-yellow     { width:260px;height:260px;background:radial-gradient(circle,#ffe000 0%,transparent 70%);top:-80px;left:42%;opacity:.38;animation-delay:-3s; }
  .orb-green      { width:280px;height:280px;background:radial-gradient(circle,#00ff5e 0%,transparent 70%);top:-90px;right:-60px;opacity:.42;animation-delay:-6s; }
  .orb-red-bottom { width:180px;height:180px;background:radial-gradient(circle,#ff2020 0%,transparent 70%);bottom:-60px;right:20%;opacity:.2;animation-delay:-1.5s; }
  .orb-green-bottom{width:160px;height:160px;background:radial-gradient(circle,#00ff5e 0%,transparent 70%);bottom:-50px;left:15%;opacity:.18;animation-delay:-4.5s; }

  @keyframes drift {
    0%   { transform: translate(0,0) scale(1); }
    33%  { transform: translate(20px,-14px) scale(1.07); }
    66%  { transform: translate(-12px,9px) scale(0.96); }
    100% { transform: translate(14px,-7px) scale(1.04); }
  }

  .footer-glass-panel {
    position: relative;
    z-index: 2;
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    padding: 2.5rem 1rem 2rem;
  }

  .footer-logo {
    font-family: 'Space Mono', monospace;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    background: linear-gradient(90deg, #ff2020, #ffe000, #00ff5e, #ffe000, #ff2020);
    background-size: 300% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradientShift 5s ease-in-out infinite alternate;
  }
  @keyframes gradientShift {
    0%   { background-position: 0% 50%; }
    100% { background-position: 100% 50%; }
  }

  .semaforo-deco { display:flex;justify-content:center;gap:6px;margin:0.6rem auto 0.5rem; }
  .semaforo-dot  { width:9px;height:9px;border-radius:50%;animation:pulse-dot 3s ease-in-out infinite; }
  .sd-red    { background:#ff2020;box-shadow:0 0 8px #ff2020;animation-delay:0s; }
  .sd-yellow { background:#ffe000;box-shadow:0 0 8px #ffe000;animation-delay:1s; }
  .sd-green  { background:#00ff5e;box-shadow:0 0 8px #00ff5e;animation-delay:2s; }
  @keyframes pulse-dot {
    0%,100% { opacity:.3;transform:scale(.85); }
    33%      { opacity:1;transform:scale(1.3); }
  }

  .footer-rule { width:55px;height:2px;margin:0.6rem auto 1.3rem;border-radius:99px;background:linear-gradient(90deg,#ff2020,#ffe000,#00ff5e); }

  .info-pill {
    display:inline-flex;align-items:center;gap:7px;
    background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);
    border-radius:99px;padding:6px 16px;
    font-family:'Outfit',sans-serif;font-size:0.79rem;
    color:rgba(230,240,230,0.82);letter-spacing:0.02em;
    transition:background .25s,border-color .25s,transform .2s,box-shadow .25s;
  }
  .info-pill:hover               { background:rgba(255,255,255,0.08);transform:translateY(-2px); }
  .pill-red:hover    { border-color:rgba(255,32,32,0.5);  box-shadow:0 4px 20px rgba(255,32,32,0.15); }
  .pill-yellow:hover { border-color:rgba(255,224,0,0.5);  box-shadow:0 4px 20px rgba(255,224,0,0.15); }
  .pill-green:hover  { border-color:rgba(0,255,94,0.5);   box-shadow:0 4px 20px rgba(0,255,94,0.15); }
  .icon-red    { color:#ff2020; }
  .icon-yellow { color:#ffe000; }
  .icon-green  { color:#00ff5e; }
  .pills-row { display:flex;flex-wrap:wrap;gap:9px;justify-content:center;margin-bottom:1.3rem; }

  .footer-privacy {
    font-family:'Outfit',sans-serif;font-size:0.75rem;letter-spacing:0.1em;
    text-transform:uppercase;color:rgba(200,230,200,0.45);text-decoration:none;
    border-bottom:1px dashed rgba(0,255,94,0.2);padding-bottom:1px;
    transition:color .2s,border-color .2s,text-shadow .2s;
  }
  .footer-privacy:hover { color:#00ff5e;border-color:#00ff5e;text-shadow:0 0 10px rgba(0,255,94,0.6); }

  .footer-copy { font-family:'Outfit',sans-serif;font-size:0.68rem;letter-spacing:0.05em;color:rgba(200,220,200,0.22);margin-top:1.1rem;margin-bottom:0; }

  .sparkle { position:absolute;width:3px;height:3px;border-radius:50%;animation:twinkle 3s ease-in-out infinite;z-index:1; }
  @keyframes twinkle {
    0%,100% { opacity:0;transform:scale(.5); }
    50%      { opacity:1;transform:scale(1.6); }
  }
</style>


