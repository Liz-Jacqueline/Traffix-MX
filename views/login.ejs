<!DOCTYPE html> 
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TRAFFIX MX</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Exo+2:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&family=Space+Mono:wght@400;700&display=swap"
        rel="stylesheet">

    <!-- CSS -->
    <link rel="stylesheet" href="/css/pages/home.css">
    <link rel="stylesheet" href="/css/components/navbar.css">
    <link rel="stylesheet" href="/css/pages/login.css">
    <link rel="stylesheet" href="/css/pages/cards.css">
    <link rel="stylesheet" href="/css/pages/pie.css">
    <script defer src="/js/cards.js"></script>

    <!-- login -->
    <link
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=Montserrat:wght@300;400;500;600&display=swap"
        rel="stylesheet">

</head>

<body id="top">

    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container-fluid">
            <a href="/"
                style="background-image: url(/images/home/logo.png); background-size: contain; background-repeat: no-repeat; width: 100px; height: 100px;"></a>
            <a class="navbar-brand" href="/">
                TRAFFIX MX
            </a>


            <a href="/" class="btn btn-warning">Regresar</a>

        </div>
    </nav>

    <div class="body-login">
        <div class="bg"></div>
        <div class="scanlines"></div>

        <div class="wrapper" id="wrapper">

            <div class="forms-area">

                <!-- SIGN IN -->
                <div class="form-panel signin-panel">
                    <p class="form-sub">Bienvenido de vuelta</p>
                    <h2 class="form-title">Inicio de Sesión</h2>

                    <div class="socials">
                        <div class="social-icon">G</div>
                        <div class="social-icon">f</div>
                        <div class="social-icon">GH</div>
                        <div class="social-icon">in</div>
                    </div>

                    <!-- LOGIN -->
                    <form action="/login" method="POST">

                        <div class="field">
                            <input type="email" name="email" placeholder="Correo electrónico" required>
                        </div>

                        <div class="field">
                            <input type="password" name="password" placeholder="Contraseña" required>
                        </div>

                        <a href="#" class="forgot">¿Olvidaste tu contraseña?</a>

                        <button type="submit" class="submit-btn">
                            Iniciar Sesión
                        </button>

                    </form>

                    <p class="mobile-toggle">
                        ¿No tienes cuenta?
                        <a href="#" onclick="setMode('signup'); return false;">Regístrate</a>
                    </p>
                </div>

                <!-- SIGN UP -->
                <div class="form-panel signup-panel">
                    <p class="form-sub">Únete ahora</p>
                    <h2 class="form-title">Crear Cuenta</h2>

                    <div class="socials">
                        <div class="social-icon">G</div>
                        <div class="social-icon">f</div>
                        <div class="social-icon">GH</div>
                        <div class="social-icon">in</div>
                    </div>

                    <div class="or-divider"><span>o con email</span></div>

                    <!-- REGISTER -->
                    <form action="/register" method="POST">

                        <div class="field">
                            <input type="text" name="name" placeholder="Nombre completo" required>
                        </div>

                        <div class="field">
                            <input type="email" name="email" placeholder="Correo electrónico" required>
                        </div>

                        <div class="field">
                            <input type="password" name="password" placeholder="Contraseña" required>
                        </div>

                        <button type="submit" class="submit-btn">
                            Registrarse
                        </button>

                    </form>

                    <p class="mobile-toggle">
                        ¿Ya tienes cuenta?
                        <a href="#" onclick="setMode('signin'); return false;">Inicia sesión</a>
                    </p>
                </div>

            </div>

            <!-- PANEL DESLIZANTE -->
            <div class="slider" id="slider">

                <div id="slider-signin-content">
                    <span class="slider-badge">TRAFFIX MX</span>
                    <div class="slider-line"></div>
                    <h2>¿Ya tienes una<br><em>Cuenta?</em></h2>
                    <p>Inicia sesión y continúa trabajando.</p>
                    <button class="slider-btn" onclick="setMode('signup')">
                        <span>← Iniciar Sesion </span>
                    </button>
                </div>

                <div id="slider-signup-content" style="display:none;">
                    <span class="slider-badge">TRAFFIX MX</span>
                    <div class="slider-line"></div>
                    <h2>¿No tienes<br><em>Cuenta?</em></h2>
                    <p>Regístrate ahora y accede a nuestro servicio.</p>
                    <div class="slider-line"></div>
                    <button class="slider-btn" onclick="setMode('signin')">
                        <span> Registrarme →</span>
                    </button>
                </div>

            </div>

        </div>
    </div>

    <!-- Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- JS propio -->
    <script src="/js/navbar.js"></script>
    <script src="/js/login.js"></script>

</body>

</html>