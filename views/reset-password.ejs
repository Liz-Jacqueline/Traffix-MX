<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TRAFFIX MX – Nueva Contraseña</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Exo+2:wght@400;600;700;800&family=Outfit:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/components/navbar.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            min-height: 100vh; background: #0a0a0a;
            font-family: 'Outfit', sans-serif;
            display: flex; flex-direction: column;
        }
        .bg-layer {
            position: fixed; inset: 0; z-index: 0;
            background:
                radial-gradient(ellipse 80% 50% at 20% 40%, rgba(245,197,24,0.07) 0%, transparent 60%),
                radial-gradient(ellipse 60% 40% at 80% 70%, rgba(245,197,24,0.04) 0%, transparent 50%);
        }
        .scanlines {
            position: fixed; inset: 0; z-index: 1; pointer-events: none;
            background: repeating-linear-gradient(to bottom,
                transparent 0px, transparent 3px,
                rgba(0,0,0,0.15) 3px, rgba(0,0,0,0.15) 4px);
        }
        .page-wrapper {
            flex: 1; display: flex; align-items: center;
            justify-content: center; padding: 60px 20px;
            position: relative; z-index: 2;
        }
        .card-panel {
            width: 100%; max-width: 460px;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(245,197,24,0.25);
            border-radius: 16px; padding: 48px 40px;
            backdrop-filter: blur(12px);
            animation: fadeUp 0.6s ease both;
        }
        @keyframes fadeUp {
            from { opacity:0; transform:translateY(24px); }
            to   { opacity:1; transform:translateY(0); }
        }
        .badge-tag {
            display: inline-block;
            font-family: 'Exo 2', sans-serif; font-size: 11px;
            font-weight: 800; letter-spacing: 3px; color: #f5c518;
            background: rgba(245,197,24,0.1); border: 1px solid rgba(245,197,24,0.3);
            padding: 4px 12px; border-radius: 4px; margin-bottom: 20px;
        }
        h2 { font-family: 'Exo 2', sans-serif; font-size: 26px; font-weight: 800;
             color: #fff; margin-bottom: 10px; line-height: 1.2; }
        h2 em { color: #f5c518; font-style: normal; }
        .subtitle { color: #888; font-size: 14px; line-height: 1.6; margin-bottom: 32px; }

        .alert-custom {
            padding: 14px 18px; border-radius: 8px; font-size: 14px;
            margin-bottom: 24px; display: flex; align-items: flex-start; gap: 10px;
        }
        .alert-error-custom { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3); color: #f87171; }
        .alert-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }

        .field { margin-bottom: 20px; }
        .field label {
            display: block; font-size: 12px; font-weight: 600;
            letter-spacing: 1.5px; color: #888; margin-bottom: 8px; text-transform: uppercase;
        }
        .field input {
            width: 100%; background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.12); border-radius: 8px;
            padding: 14px 18px; color: #fff; font-family: 'Outfit', sans-serif;
            font-size: 15px; outline: none; transition: border-color 0.2s, background 0.2s;
        }
        .field input:focus { border-color: #f5c518; background: rgba(245,197,24,0.06); }
        .field input::placeholder { color: #555; }

        /* Strength meter */
        .strength-bar { height: 4px; border-radius: 2px; margin-top: 8px;
                        background: rgba(255,255,255,0.1); overflow: hidden; }
        .strength-fill { height: 100%; width: 0; border-radius: 2px;
                         transition: width 0.3s, background 0.3s; }
        .strength-label { font-size: 11px; color: #666; margin-top: 4px; height: 16px; }

        .submit-btn {
            width: 100%; padding: 15px; background: #f5c518; color: #0a0a0a;
            font-family: 'Exo 2', sans-serif; font-size: 14px; font-weight: 800;
            letter-spacing: 2px; border: none; border-radius: 8px; cursor: pointer;
            transition: transform 0.15s, box-shadow 0.15s, background 0.15s; margin-top: 8px;
        }
        .submit-btn:hover { background: #ffd740; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(245,197,24,0.3); }
        .submit-btn:active { transform: translateY(0); }
        .submit-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

        .divider { height: 1px; background: rgba(255,255,255,0.08); margin: 28px 0; }
        .back-link { text-align: center; margin-top: 28px; font-size: 14px; color: #666; }
        .back-link a { color: #f5c518; text-decoration: none; font-weight: 600; transition: opacity 0.2s; }
        .back-link a:hover { opacity: 0.8; }

        /* Match indicator */
        .match-msg { font-size: 11px; margin-top: 6px; height: 16px; }
        .match-ok { color: #4ade80; }
        .match-no { color: #f87171; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container-fluid">
            <a href="/" style="background-image:url(/images/home/logo.png);background-size:contain;background-repeat:no-repeat;width:100px;height:100px;"></a>
            <a class="navbar-brand" href="/">TRAFFIX MX</a>
            <a href="/login" class="btn btn-warning">Iniciar Sesión</a>
        </div>
    </nav>

    <div class="bg-layer"></div>
    <div class="scanlines"></div>

    <div class="page-wrapper">
        <div class="card-panel">

            <div class="badge-tag">TRAFFIX MX</div>
            <h2>Nueva<br><em>contraseña</em></h2>
            <p class="subtitle">Elige una contraseña segura para tu cuenta.</p>

            <!-- Error -->
            <% if (typeof query !== 'undefined' && query.error) { %>
            <div class="alert-custom alert-error-custom">
                <span class="alert-icon">✕</span>
                <span><%= query.error %></span>
            </div>
            <% } %>

            <form action="/reset-password" method="POST" id="resetForm">
                <input type="hidden" name="token" value="<%= token %>">

                <div class="field">
                    <label>Nueva contraseña</label>
                    <input type="password" name="password" id="password"
                           placeholder="Mínimo 8 caracteres" required minlength="8">
                    <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
                    <div class="strength-label" id="strengthLabel"></div>
                </div>

                <div class="field">
                    <label>Confirmar contraseña</label>
                    <input type="password" name="confirmPassword" id="confirmPassword"
                           placeholder="Repite tu contraseña" required>
                    <div class="match-msg" id="matchMsg"></div>
                </div>

                <button type="submit" class="submit-btn" id="submitBtn" disabled>
                    CAMBIAR CONTRASEÑA
                </button>
            </form>

            <div class="divider"></div>
            <div class="back-link"><a href="/login">← Volver al inicio de sesión</a></div>
        </div>
    </div>

    <script>
        const pwd     = document.getElementById('password')
        const confirm = document.getElementById('confirmPassword')
        const fill    = document.getElementById('strengthFill')
        const label   = document.getElementById('strengthLabel')
        const matchM  = document.getElementById('matchMsg')
        const btn     = document.getElementById('submitBtn')

        const levels = [
            { min: 0,  max: 29,  color: '#ef4444', text: 'Muy débil',  pct: '20%' },
            { min: 30, max: 49,  color: '#f97316', text: 'Débil',       pct: '40%' },
            { min: 50, max: 69,  color: '#eab308', text: 'Regular',     pct: '60%' },
            { min: 70, max: 89,  color: '#84cc16', text: 'Fuerte',      pct: '80%' },
            { min: 90, max: 100, color: '#22c55e', text: 'Muy fuerte',  pct: '100%' },
        ]

        function score(p) {
            let s = 0
            if (p.length >= 8)  s += 20
            if (p.length >= 12) s += 10
            if (/[A-Z]/.test(p)) s += 20
            if (/[0-9]/.test(p)) s += 20
            if (/[^A-Za-z0-9]/.test(p)) s += 30
            return Math.min(s, 100)
        }

        function validate() {
            const s = score(pwd.value)
            const lvl = levels.find(l => s >= l.min && s <= l.max) || levels[0]
            fill.style.width = pwd.value ? lvl.pct : '0'
            fill.style.background = lvl.color
            label.textContent = pwd.value ? lvl.text : ''
            label.style.color = lvl.color

            const match = pwd.value && confirm.value && pwd.value === confirm.value
            const noMatch = confirm.value && pwd.value !== confirm.value
            matchM.textContent = match ? '✓ Las contraseñas coinciden' : noMatch ? '✕ No coinciden' : ''
            matchM.className = 'match-msg ' + (match ? 'match-ok' : noMatch ? 'match-no' : '')

            btn.disabled = !(match && s >= 30)
        }

        pwd.addEventListener('input', validate)
        confirm.addEventListener('input', validate)
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/navbar.js"></script>
</body>
</html>
