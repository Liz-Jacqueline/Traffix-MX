<%- include("templates/encabezado") %>

    <section class="hero" style="background-image: url('/images/home/arcos.png');">
        <div class="hero-overlay">
            <h1>TRAFFIX MX</h1>
            <p>El crecimiento acelerado de las ciudades ha provocado que uno de los problemas más comunes en las grandes
                ciudades es el tráfico vehicular denso y la movilidad urbana deficiente.
                Como empresa buscamos brindar una solución tecnológica a través de un sistema de semaforización
                inteligente que permitan controlar de manera más eficaz y eficiente el flujo de tránsito de una ciudad
            </p>
        </div>
    </section>

    <div style="padding: 1%; height: 450px;">
        <img src="/images/home/mapa.png" alt="Misión"
            style="width: 500px; height: 320px; border-radius: 15px; margin-top: 50px; margin-left: 50px;">

        <div class="col-lg-6 text-white pe-lg-4" style="width: 50%; padding: 2%; float: right;">
            <h2 class="fw-bold display-5">Misión.</h2>
            <br><br>
            <p class="mt-3">
                Consolidar el proyecto como una plataforma de simulación en software que, en una primera etapa permite
                analizar y optimizar el control semafórico adaptativo mediante programación, y, que en etapas
                posteriores pueda evolucionar hacia la integración de tecnologías IoT e inteligencia artificial, con el
                objetivo de apoyar el desarrollo de soluciones reales y sostenibles para la movilidad urbana.
            </p>
        </div>
    </div>

    <div style="padding: 1%; height: 450px;">
        <div class="col-lg-6 text-white pe-lg-4" style="width: 50%; float: inline-start; padding: 2%;">
            <h2 class="fw-bold display-5">Vision.</h2>
            <br><br>
            <p class="mt-3">
                Consolidar el proyecto como una plataforma de simulación en software que, en una primera etapa permite
                analizar y optimizar el control semafórico adaptativo mediante programación, y, que en etapas
                posteriores pueda evolucionar hacia la integración de tecnologías IoT e inteligencia artificial, con el
                objetivo de apoyar el desarrollo de soluciones reales y sostenibles para la movilidad urbana.
            </p>
        </div>

        <div class="container my-5">
            <div class="row justify-content-center g-4">
                <div class="col-12 col-md-4 d-flex justify-content-center" style="padding-top: 45px;">
                    <img src="/images/home/verde.png" class="img-fluid rounded shadow"
                        style="height: 300px; width: 100%; object-fit: cover;" alt="Panel 1">
                </div>
                <div class="col-12 col-md-4 d-flex justify-content-center">
                    <img src="/images/home/amarillo.png" class="img-fluid rounded shadow"
                        style="height: 400px; width: 100%; object-fit: cover;" alt="Panel 2">
                </div>
                <div class="col-12 col-md-4 d-flex justify-content-center" style="padding-top: 50px;">
                    <img src="/images/home/rojo.png" class="img-fluid rounded shadow"
                        style="height: 300px; width: 100%; object-fit: cover;" alt="Panel 3">
                </div>
            </div>
        </div>
    </div>

    <!-- ===================== TARJETAS SEMÁFORO ===================== -->
  <div id="servicios" style="background: #0a0a0a; padding: 80px 60px;">
  

  <div class="sem-grid">

    <!-- VERDE — Sistema Semaforico -->
    <div class="sem-card verde">
      <div class="sem-accent-bar"></div>
      <div class="sem-icon-wrap">
        <div class="sem-icon-glow"></div>
        <div class="sem-icon-ring"></div>
        <svg viewBox="0 0 48 48">
          <rect x="15" y="4" width="18" height="38" rx="4"/>
          <circle cx="24" cy="13" r="4" fill="rgba(255,255,255,0.1)"/>
          <circle cx="24" cy="24" r="4" fill="rgba(255,255,255,0.1)"/>
          <circle cx="24" cy="35" r="4" fill="rgba(34,197,94,0.9)" stroke="none"/>
          <line x1="24" y1="42" x2="24" y2="46"/>
          <line x1="18" y1="46" x2="30" y2="46"/>
          <path d="M19 35l3 3 6-6" stroke="#0a0a0a" stroke-width="1.5" fill="none"/>
        </svg>
      </div>
      <div class="sem-label">Sistema Semaforico</div>
      <div class="sem-desc">Control adaptativo del flujo vehicular en tiempo real. Optimización inteligente de fases y tiempos por intersección.</div>
      <a href="#" class="sem-link">
        Ver sistema
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 8h10M9 4l4 4-4 4"/>
        </svg>
      </a>
    </div>

    <!-- AMARILLO — Estadísticas -->
    <div class="sem-card amarillo">
      <div class="sem-accent-bar"></div>
      <div class="sem-icon-wrap">
        <div class="sem-icon-glow"></div>
        <div class="sem-icon-ring"></div>
        <svg viewBox="0 0 48 48">
          <!-- bar chart -->
          <rect x="6"  y="28" width="8" height="14" rx="2"/>
          <rect x="20" y="18" width="8" height="24" rx="2"/>
          <rect x="34" y="10" width="8" height="32" rx="2"/>
          <!-- trend line -->
          <path d="M10 26 L24 16 L38 8" stroke-dasharray="3 2" opacity="0.5"/>
          <circle cx="10" cy="26" r="2" fill="currentColor" stroke="none"/>
          <circle cx="24" cy="16" r="2" fill="currentColor" stroke="none"/>
          <circle cx="38" cy="8"  r="2" fill="currentColor" stroke="none"/>
        </svg>
      </div>
      <div class="sem-label">Estadísticas</div>
      <div class="sem-desc">Métricas de tráfico, tiempos de espera y eficiencia por zona. Reportes históricos y análisis de patrones de movilidad.</div>
      <a href="#" class="sem-link">
        Ver estadísticas
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 8h10M9 4l4 4-4 4"/>
        </svg>
      </a>
    </div>

    <!-- ROJO — Simulaciones -->
    <div class="sem-card rojo">
      <div class="sem-accent-bar"></div>
      <div class="sem-icon-wrap">
        <div class="sem-icon-glow"></div>
        <div class="sem-icon-ring"></div>
        <svg viewBox="0 0 48 48">
          <!-- play button / simulation icon -->
          <circle cx="24" cy="24" r="18"/>
          <path d="M20 16l12 8-12 8V16z" fill="rgba(239,68,68,0.3)" stroke="currentColor"/>
          <!-- small dots suggesting traffic -->
          <circle cx="10" cy="24" r="1.5" fill="currentColor" stroke="none" opacity="0.6"/>
          <circle cx="38" cy="24" r="1.5" fill="currentColor" stroke="none" opacity="0.6"/>
          <circle cx="24" cy="10" r="1.5" fill="currentColor" stroke="none" opacity="0.6"/>
          <circle cx="24" cy="38" r="1.5" fill="currentColor" stroke="none" opacity="0.6"/>
        </svg>
      </div>
      <div class="sem-label">Simulaciones</div>
      <div class="sem-desc">Modelado virtual de escenarios de tráfico urbano. Prueba configuraciones semafóricas antes de implementarlas en campo.</div>
      <a href="#" class="sem-link">
        Ver simulaciones
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 8h10M9 4l4 4-4 4"/>
        </svg>
      </a>
    </div>

  </div>
</div>

    <%- include("templates/pie") %>